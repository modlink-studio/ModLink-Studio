# Copy this file to .env for local development.
# The plugin agent reads tools/modlink_plugin_agent/.env and the current
# working directory .env. Real environment variables always take precedence.

MODLINK_AI_BASE_URL=https://api.example.com/v1
MODLINK_AI_MODEL=gpt-compatible-model
MODLINK_AI_API_KEY=replace-with-your-api-key
